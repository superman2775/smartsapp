{
  "name": "smartschool-messenger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite",
    "deploy:rules": "firebase deploy --only firestore:rules,storage:rules",
    "deploy:rules:firestore": "firebase deploy --only firestore:rules",
    "deploy:rules:storage": "firebase deploy --only storage:rules",
    "deploy:cors": "echo 'Deploy CORS via Firebase Console > Storage > Rules tab, or run: gsutil cors set cors.json gs://smartsapp-16c71.firebasestorage.app (requires gcloud SDK)'"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "firebase": "^10.12.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "firebase-tools": "^13.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
